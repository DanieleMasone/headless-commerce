{
  "name": "headless-commerce",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise-grade static headless commerce portfolio built with Next.js App Router.",
  "engines": {
    "node": "24.15.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next typegen && node scripts/prepare-next-types.mjs && next build && node scripts/prepare-next-types.mjs",
    "start": "node scripts/serve-static.mjs",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "next typegen && node scripts/prepare-next-types.mjs && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright install --with-deps chromium && playwright test",
    "docs": "npm run docs:clean && typedoc",
    "docs:clean": "node scripts/clean-docs.mjs",
    "expose:reports": "node scripts/expose-reports.mjs",
    "ci": "npm run format:check && npm run lint && npm run typecheck && npm run test:coverage && npm run test:e2e && npm run docs && npm run build && npm run expose:reports",
    "deploy:check": "npm run test:coverage && npm run docs && npm run build && npm run expose:reports && node scripts/assert-static-export.mjs"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "overrides": {
    "@typescript-eslint/typescript-estree": {
      "brace-expansion": "5.0.6"
    },
    "next": {
      "postcss": "8.5.10"
    }
  },
  "devDependencies": {
    "@emnapi/core": "1.10.0",
    "@emnapi/runtime": "1.10.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
