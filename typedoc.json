{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "src/components/cart",
    "src/components/product",
    "src/components/theme",
    "src/components/ui",
    "src/lib/cart",
    "src/lib/checkout",
    "src/lib/products",
    "src/lib/theme",
    "src/lib/format.ts",
    "src/lib/routing.ts",
    "src/types"
  ],
  "entryPointStrategy": "expand",
  "exclude": ["**/*.test.ts", "**/*.test.tsx"],
  "excludePrivate": true,
  "hideGenerator": true,
  "out": "docs",
  "plugin": [],
  "readme": "typedoc-index.md",
  "tsconfig": "tsconfig.typedoc.json"
}
